{
  "skill": "centrality",
  "description": "Parity for the 14 centrality/ranking tools. Fixture is the 5-function diamond used by the reachability Skill — small enough to compute scores exactly, large enough to give non-trivial rankings.",
  "cases": [
    {
      "capability": "rank_symbols",
      "name": "top_5",
      "fixture": "diamond_call_graph",
      "cli_args": ["rank-symbols", "--limit", "5", "--format", "json"],
      "mcp_input": {"limit": 5},
      "parity_invariant": "CLI ranked list == MCP `ranked` array"
    },
    {
      "capability": "get_top_files",
      "name": "top_5_files",
      "fixture": "diamond_call_graph",
      "cli_args": ["get-top-files", "--limit", "5", "--format", "json"],
      "mcp_input": {"limit": 5},
      "expected_field_keys": ["files"]
    },
    {
      "capability": "get_most_connected",
      "name": "top_5_connected",
      "fixture": "diamond_call_graph",
      "cli_args": ["get-most-connected", "--limit", "5", "--format", "json"],
      "mcp_input": {"limit": 5}
    },
    {
      "capability": "get_hub_symbols",
      "name": "top_5_hubs",
      "fixture": "diamond_call_graph",
