  "fixture_definitions": {
    "diamond_call_graph": {
      "description": "Shared with reachability Skill — 5-function diamond.",
      "files": {
        "Cargo.toml": "[package]\nname=\"q\"\nversion=\"0.0.0\"\nedition=\"2021\"\n",
        "src/lib.rs": "pub fn d() -> i32 { 4 }\npub fn e() -> i32 { 5 }\npub fn c() -> i32 { d() + 1 }\npub fn b() -> i32 { c() + e() }\npub fn a() -> i32 { b() * 2 }\n"
      },
      "index_command": ["mycelium", "index", "."]
    }
  }
