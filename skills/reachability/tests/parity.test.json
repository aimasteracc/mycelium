{
  "skill": "reachability",
  "description": "Parity for the 12 multi-hop tools. Fixture: a 4-function chain (a → b → c → d) plus a fork (b → e). Exercises shortest-path, reachable, k-hop, cross-refs across the Calls edge kind.",
  "cases": [
    {
      "capability": "get_shortest_path",
      "name": "a_to_d",
      "fixture": "diamond_call_graph",
      "cli_args": ["get-shortest-path", "--from", "src/lib.rs>a", "--to", "src/lib.rs>d", "--edge-kind", "calls", "--format", "json"],
      "mcp_input": {"from": "src/lib.rs>a", "to": "src/lib.rs>d", "edge_kind": "calls"},
      "parity_invariant": "CLI path == MCP `path` array, both length 4"
    },
    {
      "capability": "get_reachable",
      "name": "from_a",
      "fixture": "diamond_call_graph",
      "cli_args": ["get-reachable", "src/lib.rs>a", "--edge-kind", "calls", "--max-depth", "10", "--format", "json"],
      "mcp_input": {"path": "src/lib.rs>a", "edge_kind": "calls", "max_depth": 10},
      "expected_includes_paths": ["src/lib.rs>b", "src/lib.rs>c", "src/lib.rs>d", "src/lib.rs>e"]
    },
    {
      "capability": "get_reachable_to",
      "name": "to_d",
      "fixture": "diamond_call_graph",
      "cli_args": ["get-reachable-to", "src/lib.rs>d", "--edge-kind", "calls", "--max-depth", "10", "--format", "json"],
      "mcp_input": {"path": "src/lib.rs>d", "edge_kind": "calls", "max_depth": 10},
      "expected_includes_paths": ["src/lib.rs>a", "src/lib.rs>b", "src/lib.rs>c"]
    },
    {
      "capability": "get_k_hop_neighbors",
      "name": "k_2_from_a",
      "fixture": "diamond_call_graph",
      "cli_args": ["get-k-hop-neighbors", "src/lib.rs>a", "--k", "2", "--edge-kind", "calls", "--format", "json"],
      "mcp_input": {"path": "src/lib.rs>a", "k": 2, "edge_kind": "calls"},
      "expected_includes_paths": ["src/lib.rs>c", "src/lib.rs>e"]
    },
    {
      "capability": "get_two_hop_neighbors",
      "name": "from_a",
      "fixture": "diamond_call_graph",
      "cli_args": ["get-two-hop-neighbors", "src/lib.rs>a", "--edge-kind", "calls", "--format", "json"],
      "mcp_input": {"path": "src/lib.rs>a", "edge_kind": "calls"},
      "parity_invariant": "Same set as get_k_hop_neighbors with k=2"
    },
    {
      "capability": "get_symbol_neighborhood",
      "name": "around_b",
      "fixture": "diamond_call_graph",
      "cli_args": ["get-symbol-neighborhood", "src/lib.rs>b", "--format", "json"],
      "mcp_input": {"path": "src/lib.rs>b"},
      "expected_field_keys": ["in_calls", "out_calls"]
    },
    {
      "capability": "get_cross_refs",
      "name": "into_d",
      "fixture": "diamond_call_graph",
      "cli_args": ["get-cross-refs", "src/lib.rs>d", "--format", "json"],
      "mcp_input": {"path": "src/lib.rs>d"},
      "expected_field_keys": ["callers"]
    },
    {
      "capability": "get_outgoing_refs",
      "name": "from_a",
      "fixture": "diamond_call_graph",
      "cli_args": ["get-outgoing-refs", "src/lib.rs>a", "--format", "json"],
      "mcp_input": {"path": "src/lib.rs>a"},
      "expected_field_keys": ["callees"]
    },
    {
      "capability": "get_dependency_depth",
      "name": "depth_of_a",
      "fixture": "diamond_call_graph",
      "cli_args": ["get-dependency-depth", "src/lib.rs>a", "--edge-kind", "calls", "--format", "json"],
      "mcp_input": {"path": "src/lib.rs>a", "edge_kind": "calls"},
      "expected_field_keys": ["depth"]
    },
    {
      "capability": "get_reachable_set",
      "name": "from_seed_a_and_b",
      "fixture": "diamond_call_graph",
      "cli_args": ["get-reachable-set", "--paths", "src/lib.rs>a,src/lib.rs>b", "--edge-kind", "calls", "--max-depth", "10", "--format", "json"],
      "mcp_input": {"paths": ["src/lib.rs>a", "src/lib.rs>b"], "edge_kind": "calls", "max_depth": 10},
      "parity_invariant": "Union of reachable_from(a) and reachable_from(b)"
    },
    {
      "capability": "get_reaches_into",
      "name": "into_src_lib",
      "fixture": "diamond_call_graph",
      "cli_args": ["get-reaches-into", "--prefix", "src/lib.rs", "--edge-kind", "calls", "--format", "json"],
      "mcp_input": {"prefix": "src/lib.rs", "edge_kind": "calls"},
      "parity_invariant": "Every entry has path-prefix or reaches into one with the prefix"
    },
    {
      "capability": "get_singly_referenced",
      "name": "leaf_d",
      "fixture": "diamond_call_graph",
      "cli_args": ["get-singly-referenced", "--edge-kind", "calls", "--format", "json"],
      "mcp_input": {"edge_kind": "calls"},
      "parity_invariant": "CLI list == MCP `singly_referenced` array"
    }
  ],
  "fixture_definitions": {
    "diamond_call_graph": {
      "description": "5-function diamond. a calls b, b calls c and e, c calls d. b→e fork lets us test 2-hop tools where there are multiple paths.",
      "files": {
        "Cargo.toml": "[package]\nname=\"q\"\nversion=\"0.0.0\"\nedition=\"2021\"\n",
        "src/lib.rs": "pub fn d() -> i32 { 4 }\npub fn e() -> i32 { 5 }\npub fn c() -> i32 { d() + 1 }\npub fn b() -> i32 { c() + e() }\npub fn a() -> i32 { b() * 2 }\n"
      },
      "index_command": ["mycelium", "index", "."]
    }
  }
}
