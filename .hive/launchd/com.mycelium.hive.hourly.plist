<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTD/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        Mycelium Hive — Hourly Triage
        Triggers Triage agent every hour to sweep stale items.

        Install:
            cp .hive/launchd/com.mycelium.hive.hourly.plist ~/Library/LaunchAgents/
            launchctl load ~/Library/LaunchAgents/com.mycelium.hive.hourly.plist
    -->

    <key>Label</key>
    <string>com.mycelium.hive.hourly</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-l</string>
        <string>/Users/aisheng.yu/wiki/mycelium/scripts/hive-run.sh</string>
        <string>triage</string>
        <string>hourly-sweep</string>
    </array>

    <key>StartInterval</key>
    <integer>3600</integer>

    <key>WorkingDirectory</key>
    <string>/Users/aisheng.yu/wiki/mycelium</string>

    <key>StandardOutPath</key>
    <string>/Users/aisheng.yu/wiki/mycelium/.hive/run/hourly.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/aisheng.yu/wiki/mycelium/.hive/run/hourly.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HIVE_ROLE</key>
        <string>triage</string>
        <key>HIVE_TRIGGER</key>
        <string>hourly-sweep</string>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>KeepAlive</key>
    <false/>

    <key>ProcessType</key>
    <string>Background</string>

    <key>Nice</key>
    <integer>10</integer>
</dict>
</plist>
